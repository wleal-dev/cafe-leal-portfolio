# Supabase (produção / demo online)
# Copie a "Connection string" do painel do Supabase: Project Settings → Database → URI
DATABASE_URL=postgresql://postgres:<sua-senha>@db.<seu-projeto>.supabase.co:5432/postgres

# Local (dev) — se preferir PostgreSQL local, troque pela URL local:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cafearoma

# Gere um secret aleatório: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=troque-por-uma-chave-aleatoria-de-32-caracteres-minimo

PORT=3000

# Senhas dos usuários criados pelo seed.js
SENHA_ADMIN=Admin@1234
SENHA_CAIXA=Caixa@1234

# Protege o endpoint POST /api/admin/reset (usado pelo GitHub Actions para reset diário)
RESET_SECRET=troque-por-um-secret-aleatorio
