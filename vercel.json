{
  "version": 2,
  "builds": [
    { "src": "backend/server.js", "use": "@vercel/node" },
    { "src": "index.html",        "use": "@vercel/static" },
    { "src": "app.js",            "use": "@vercel/static" },
    { "src": "styles.css",        "use": "@vercel/static" },
    { "src": "iconeCafeAroma.png", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/backend/server.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
